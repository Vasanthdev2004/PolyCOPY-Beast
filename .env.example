# SuperFast PolyBot v3 - Environment Variables
# Copy this to .env and fill in your values

# Required: Polymarket trading wallet private key (0x-prefixed)
POLYBOT_PRIVATE_KEY=

# Optional: Telegram bot token from @BotFather
POLYBOT_TELEGRAM_TOKEN=

# Optional: Telegram allowed user IDs (comma-separated)
POLYBOT_TELEGRAM_ALLOWED_USER_IDS=

# Optional: HTTP API key for signal ingestion endpoint
POLYBOT_API_KEY=default-api-key

# Optional: Redis integrations (disabled by default for the Windows-native v3 path)
POLYBOT_REDIS_ENABLED=false
POLYBOT_REDIS_URL=redis://127.0.0.1:6379

# Optional: Execution mode (simulation | shadow | live)
POLYBOT_EXECUTION_MODE=simulation

# Optional: SQLite path for local system-of-record storage
POLYBOT_SQLITE_PATH=./polybot.db

# Optional: Override log level (default: info)
POLYBOT_LOG_LEVEL=info

# Optional: Override base position size in USD (default: 50)
POLYBOT_BASE_SIZE_USD=50
