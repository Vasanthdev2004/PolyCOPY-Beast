# SuperFast PolyBot v2.5 - Environment Variables
# Copy this to .env and fill in your values

# Required: Polymarket trading wallet private key (0x-prefixed)
POLYBOT_PRIVATE_KEY=

# Required: Telegram bot token from @BotFather
POLYBOT_TELEGRAM_TOKEN=

# Required: Telegram allowed user IDs (comma-separated) — v2.5 auth
TELEGRAM_ALLOWED_USER_IDS=

# Optional: HTTP API key for signal ingestion endpoint
POLYBOT_API_KEY=default-api-key

# Optional: Redis URL (default: redis://127.0.0.1:6379)
POLYBOT_REDIS_URL=redis://127.0.0.1:6379

# Optional: Override simulation mode (default: true)
POLYBOT_SIMULATION=true

# Optional: Override log level (default: info)
POLYBOT_LOG_LEVEL=info

# Optional: Override base position size in USD (default: 50)
POLYBOT_BASE_SIZE_USD=50
